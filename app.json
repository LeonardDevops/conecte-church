{
  "expo": {
    "name": "Conecte Church",
    "slug": "conecte-church",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png", 
    "scheme": "conecte-church",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leonardo92.meta",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0072B1",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.leonardo92.meta",
      "versionCode": 4
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "O aplicativo precisa acessar seu calendário para agendar eventos da igreja."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0072B1" 
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O aplicativo acessa suas fotos para permitir o compartilhamento com a comunidade."
        }
      ],
      "expo-web-browser",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "87740c97-0dc1-4462-a097-de851cc81c5b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/87740c97-0dc1-4462-a097-de851cc81c5b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}